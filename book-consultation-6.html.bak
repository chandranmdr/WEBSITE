<!-- ONLINE BOOKING FORM -->
<section class="section-alt" id="enquiry-form">
<div class="container">
  <div style="text-align:center;margin-bottom:40px">
    <div class="slabel">Online Enquiry</div>
    <h2 class="stitle">Send an Appointment Request</h2>
    <p class="ssub" style="margin:0 auto">Complete the form below and Wendy will be in touch within one working day to confirm your appointment. All fields marked <span style="color:#c5a44e">*</span> are required.</p>
  </div>

  <div class="form-wrap">
    <form id="consultForm" name="consultation-enquiry" method="POST" data-netlify="true" data-netlify-honeypot="bot-field">
      <!-- Netlify hidden field required for form detection -->
      <input type="hidden" name="form-name" value="consultation-enquiry">
      <!-- Honeypot spam field - hidden from real users -->
      <p style="display:none"><label>Don't fill this out: <input name="bot-field"></label></p>
      <div class="form-grid">

        <div class="form-group">
          <label>Full Name <span>*</span></label>
          <input type="text" name="full_name" class="form-control" placeholder="e.g. John Smith" required>
        </div>

        <div class="form-group">
          <label>Phone Number <span>*</span></label>
          <input type="tel" name="phone" class="form-control" placeholder="e.g. 07700 900000" required>
        </div>

        <div class="form-group">
          <label>Email Address <span>*</span></label>
          <input type="email" name="email" class="form-control" placeholder="e.g. john@email.com" required>
        </div>

        <div class="form-group">
          <label>Preferred Contact Method <span>*</span></label>
          <select name="preferred_contact" class="form-control" required>
            <option value="" disabled selected>Please select&hellip;</option>
            <option>Phone call</option>
            <option>Email</option>
            <option>WhatsApp</option>
          </select>
        </div>

        <div class="form-group">
          <label>Type of Enquiry <span>*</span></label>
          <select name="enquiry_type" class="form-control" required>
            <option value="" disabled selected>Please select&hellip;</option>
            <option>Hip — pain / arthritis / resurfacing</option>
            <option>Hip — revision / failed replacement</option>
            <option>Knee — pain / arthritis / replacement</option>
            <option>Knee — revision / failed replacement</option>
            <option>Robotic surgery enquiry</option>
            <option>Second opinion</option>
            <option>Other / not sure</option>
          </select>
        </div>

        <div class="form-group">
          <label>Preferred Hospital <span>*</span></label>
          <select name="preferred_hospital" class="form-control" required>
            <option value="" disabled selected>Please select&hellip;</option>
            <option>The Woodlands Suite — Royal Orthopaedic Hospital</option>
            <option>Circle Health — The Priory Hospital, Birmingham</option>
            <option>HCA Healthcare — The Harborne Hospital</option>
            <option>No preference</option>
          </select>
        </div>

        <div class="form-group">
          <label>Funding / Payment <span>*</span></label>
          <select name="funding" class="form-control" required>
            <option value="" disabled selected>Please select&hellip;</option>
            <option>Private health insurance (insured)</option>
            <option>Self-pay (no insurance)</option>
            <option>Not sure yet</option>
          </select>
        </div>

        <div class="form-group">
          <label>Preferred Appointment Time</label>
          <select name="preferred_time" class="form-control">
            <option value="" disabled selected>Please select&hellip;</option>
            <option>Morning (before 12pm)</option>
            <option>Afternoon (12pm onwards)</option>
            <option>No preference</option>
          </select>
        </div>

        <div class="form-group full">
          <label>Brief Description of Symptoms or Reason for Appointment</label>
          <textarea name="message" class="form-control" placeholder="Please briefly describe your symptoms, how long you have had them, and anything else you feel is relevant. This helps Mr Hussain prepare for your consultation."></textarea>
          <p class="form-note">Please do not include sensitive medical details at this stage. Full clinical discussion will take place at your appointment.</p>
        </div>

        <div class="form-group full">
          <label style="display:flex;align-items:flex-start;gap:10px;cursor:pointer;font-weight:400;color:#5a5a5a;font-size:1rem">
            <input type="checkbox" name="consent" required style="margin-top:3px;flex-shrink:0;accent-color:#c5a44e">
            I consent to my details being used to arrange my consultation and for Wendy Richards to contact me on behalf of Mr Hussain. <span style="color:#c5a44e">*</span>
          </label>
        </div>

      </div>

      <div class="form-submit">
        <p>We aim to respond within one working day.</p>
        <button type="submit">
          Send Enquiry
          <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
        </button>
      </div>
    </form>

    <div class="form-success" id="formSuccess">
      <div class="form-success-icon">
        <svg viewBox="0 0 24 24"><path d="M22 11.08V12a10 10 0 11-5.93-9.14" stroke-linecap="round" stroke-linejoin="round"/><polyline points="22 4 12 14.01 9 11.01" stroke-linecap="round" stroke-linejoin="round"/></svg>
      </div>
      <h3>Enquiry Received</h3>
      <p class="success-sub">Thank you for getting in touch. Your enquiry has been sent to Wendy Richards, Mr Hussain's secretary, who will personally contact you to arrange your consultation.</p>

      <div class="form-success-steps">
        <div class="form-success-step">
          <div class="form-success-step-num">1</div>
          <p><strong>Wendy will be in touch</strong> within one working day by your preferred contact method.</p>
        </div>
        <div class="form-success-step">
          <div class="form-success-step-num">2</div>
          <p><strong>Your appointment will be confirmed</strong> along with your chosen hospital and any insurance details if required.</p>
        </div>
        <div class="form-success-step">
          <div class="form-success-step-num">3</div>
          <p><strong>A consultation letter</strong> will be sent to you ahead of your appointment with everything you need to know.</p>
        </div>
      </div>

      <hr class="form-success-divider">
      <p class="form-success-contact">Need to speak to someone sooner? Call or WhatsApp Wendy on <a href="tel:07772782462">07772 782462</a>.</p>
    </div>
  </div>
</div>
</section>

