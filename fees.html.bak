  ddLink.addEventListener('click', function(e){
    e.preventDefault(); e.stopPropagation();
    dd.classList.toggle('open');
  });
  dd.addEventListener('mouseenter', function(){
    if(window.getComputedStyle(document.querySelector('.nav-mobile')).display === 'none'){
      dd.classList.add('open');
    }
  });
  dd.addEventListener('mouseleave', function(){
    dd.classList.remove('open');
  });
  document.addEventListener('click', function(){ dd.classList.remove('open'); });
})();

// Procedure accordion — all start closed
function toggleAcc(id) {
  var item = document.getElementById(id);
  var isOpen = item.classList.contains('open');
  document.querySelectorAll('.acc-item').forEach(function(el){ el.classList.remove('open'); });
  if (!isOpen) { item.classList.add('open'); }
}

// FAQ — all start closed, + / - toggles correctly
function toggleFaq(el) {
  var item = el.parentElement;
  var isActive = item.classList.contains('active');
  document.querySelectorAll('.faq-item').forEach(function(fi){
    fi.classList.remove('active');
    fi.querySelector('.faq-q span').textContent = '+';
  });
  if (!isActive) {
    item.classList.add('active');
    el.querySelector('span').textContent = '−';
  }
}
</script>
</body>
</html>