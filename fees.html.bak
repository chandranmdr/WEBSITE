<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, minimum-scale=1.0, maximum-scale=5.0, user-scalable=yes">
<title>Fees & Pricing | Mr Shakir Hussain | Private Orthopaedic Surgeon Birmingham</title>
<meta name="description" content="Transparent private orthopaedic surgery fees for hip replacement, knee replacement, hip resurfacing and revision surgery with Mr Shakir Hussain in Birmingham. Self-pay and insured patients welcome.">
<meta name="keywords" content="private hip replacement cost Birmingham, private knee replacement price UK, hip resurfacing fee, revision surgery cost, orthopaedic surgeon fees Birmingham, self-pay hip surgery, insured hip replacement">
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;500;600;700&family=DM+Sans:wght@300;400;500;600;700&display=swap" rel="stylesheet">
<style>
*,*::before,*::after{margin:0;padding:0;box-sizing:border-box}
html{scroll-behavior:smooth;font-size:100%}
body{font-family:'DM Sans',sans-serif;color:#1a1a1a;background:#fafaf8;line-height:1.8;overflow-x:hidden;font-size:1.0625rem}
img{max-width:100%;display:block}
a{text-decoration:none;color:inherit;transition:color .3s}
h1,h2,h3,h4{font-family:'Playfair Display',serif;font-weight:600;line-height:1.25}
.container{max-width:1200px;margin:0 auto;padding:0 1.5rem;width:100%}
.slabel{font-family:'DM Sans',sans-serif;font-size:.78rem;font-weight:700;letter-spacing:.18em;text-transform:uppercase;color:#c5a44e;margin-bottom:.75rem}
.stitle{font-size:clamp(1.75rem,4vw,2.8rem);color:#0c1f3f;margin-bottom:1rem}
.ssub{font-size:clamp(1rem,2vw,1.1rem);color:#5a5a5a;max-width:680px;line-height:1.8}
.btn{display:inline-flex;align-items:center;gap:.5rem;padding:.9rem 2rem;border-radius:6px;font-family:'DM Sans',sans-serif;font-size:.95rem;font-weight:600;transition:all .35s;cursor:pointer;border:none;white-space:normal;text-align:center}
.btn-p{background:#c5a44e;color:#fff}.btn-p:hover{background:#ddc175}
.btn-o{background:transparent;color:#c5a44e;border:1.5px solid #c5a44e}.btn-o:hover{background:#c5a44e;color:#fff}
.btn-l{background:rgba(255,255,255,.12);color:#fff;border:1.5px solid rgba(255,255,255,.25)}.btn-l:hover{background:rgba(255,255,255,.2)}

/* NAV */
.nav{position:fixed;top:0;left:0;right:0;z-index:1000;background:#fff;border-bottom:1px solid #e2e0db}
.nav-inner{display:flex;align-items:center;justify-content:space-between;height:130px;max-width:1200px;margin:0 auto;padding:0 24px}
.nav-brand img{height:120px;width:auto;margin-left:-12px}
.nav-links{display:flex;align-items:center;gap:28px;list-style:none}
.nav-links a{font-size:.88rem;font-weight:700;color:#5a5a5a}.nav-links a:hover{color:#0c1f3f}
.nav-dropdown{position:relative}
.dropdown-menu{display:none;position:absolute;top:100%;left:0;background:#fff;border:1px solid #e2e0db;border-radius:8px;box-shadow:0 8px 24px rgba(0,0,0,.1);min-width:220px;padding:8px 0;list-style:none;z-index:2000}
.nav-dropdown.open .dropdown-menu{display:block}
.dropdown-menu li a{display:block;padding:10px 20px;font-size:.85rem;font-weight:600;color:#333;white-space:nowrap}
.dropdown-menu li a:hover{background:#f0efeb;color:#c5a44e}
.nav-cta .btn{padding:10px 24px;font-size:.85rem}
.nav-mobile{display:none;background:none;border:2px solid #c5a44e;border-radius:4px;cursor:pointer;padding:8px}

/* PAGE HERO */
.page-hero{padding:160px 0 80px;background:linear-gradient(135deg,#0c1f3f,#162d55,#1a3460);position:relative;overflow:hidden}
.page-hero::after{content:'';position:absolute;bottom:0;left:0;right:0;height:4px;background:linear-gradient(90deg,#c5a44e,#ddc175,#c5a44e)}
.page-hero-inner{max-width:780px}
.page-hero .slabel{color:#c5a44e}
.page-hero h1{font-size:clamp(2.2rem,5vw,3.4rem);color:#fff;margin-bottom:20px}
.page-hero p{font-size:1.15rem;color:#a0aec0;line-height:1.8}
.page-hero-badges{display:flex;gap:16px;flex-wrap:wrap;margin-top:32px}
.hero-badge{display:flex;align-items:center;gap:8px;background:rgba(255,255,255,.08);border:1px solid rgba(255,255,255,.15);border-radius:40px;padding:8px 20px;font-size:.9rem;color:#fff;font-weight:500}
.hero-badge svg{stroke:#c5a44e;fill:none;width:16px;height:16px;stroke-width:2.5;flex-shrink:0}

/* CONSULTATION FEES */
.consult-fees{padding:90px 0;background:#fff}
.price-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:28px;max-width:1020px;margin:48px auto 0}
.price-card{background:#fafaf8;border:1px solid #e2e0db;border-radius:12px;padding:44px 36px;text-align:center;position:relative}
.price-card.feat{border-color:#c5a44e;box-shadow:0 8px 40px rgba(197,164,78,.14);background:#fff}
.price-card h3{font-size:clamp(1.05rem,2.5vw,1.25rem);color:#0c1f3f;margin-bottom:.5rem}
.price-amt{font-family:'Playfair Display',serif;font-size:clamp(2rem,5vw,2.8rem);font-weight:700;color:#0c1f3f;margin:1.25rem 0 .625rem}
.price-note{font-size:clamp(.85rem,2vw,.9rem);color:#5a5a5a;margin-bottom:1.75rem;line-height:1.6}
.price-feat{list-style:none;text-align:left;margin-bottom:2rem}
.price-feat li{font-size:clamp(.88rem,2vw,.95rem);color:#5a5a5a;padding:.625rem 0;border-bottom:1px solid #e2e0db;display:flex;gap:.75rem;line-height:1.55}
.price-feat li:last-child{border-bottom:none}
.price-feat svg{flex-shrink:0;margin-top:3px;width:17px;height:17px;stroke:#c5a44e;fill:none;stroke-width:2.5}
.price-badge{position:absolute;top:-14px;left:50%;transform:translateX(-50%);background:#c5a44e;color:#fff;font-size:.72rem;font-weight:700;letter-spacing:.08em;text-transform:uppercase;padding:5px 18px;border-radius:20px;white-space:nowrap}

/* PROCEDURE FEES */
.proc-fees{padding:90px 0;background:#f0efeb}
.proc-intro{text-align:center;max-width:700px;margin:0 auto 60px}
.proc-intro .ssub{margin:0 auto}

/* ACCORDION */
.acc-list{display:flex;flex-direction:column;gap:0;max-width:960px;margin:0 auto;border-radius:12px;overflow:hidden;box-shadow:0 4px 24px rgba(12,31,63,.08)}
.acc-item{background:#fff;border-bottom:1px solid #e2e0db}
.acc-item:last-child{border-bottom:none}
.acc-header{display:flex;align-items:center;justify-content:space-between;padding:clamp(1rem,3vw,1.75rem) clamp(1rem,3vw,2.25rem);cursor:pointer;gap:1.25rem;transition:background .25s}
.acc-header:hover{background:#fafaf8}
.acc-item.open .acc-header{background:#fafaf8;border-bottom:1px solid #e2e0db}
.acc-icon-wrap{display:flex;align-items:center;gap:18px;flex:1}
.acc-icon{width:clamp(40px,6vw,52px);height:clamp(40px,6vw,52px);border-radius:50%;background:#0c1f3f;display:flex;align-items:center;justify-content:center;flex-shrink:0}
.acc-icon svg{stroke:#c5a44e;fill:none;width:24px;height:24px;stroke-width:1.8}
.acc-title-group{flex:1}
.acc-title{font-family:'Playfair Display',serif;font-size:clamp(1rem,3vw,1.3rem);color:#0c1f3f;font-weight:600;margin-bottom:.25rem}
.acc-subtitle{font-size:.9rem;color:#5a5a5a}
.acc-price-preview{font-family:'Playfair Display',serif;font-size:1.5rem;font-weight:700;color:#c5a44e;white-space:nowrap;margin-right:16px}
.acc-chevron{width:28px;height:28px;border-radius:50%;background:#f0efeb;display:flex;align-items:center;justify-content:center;flex-shrink:0;transition:transform .35s}
.acc-item.open .acc-chevron{transform:rotate(180deg);background:#c5a44e}
.acc-chevron svg{stroke:#0c1f3f;fill:none;width:14px;height:14px;stroke-width:2.5}
.acc-item.open .acc-chevron svg{stroke:#fff}
.acc-body{max-height:0;overflow:hidden;transition:max-height .5s ease}
.acc-item.open .acc-body{max-height:2000px}
.acc-inner{padding:0 clamp(1rem,3vw,2.25rem) clamp(1rem,3vw,2.25rem)}
.acc-grid{display:grid;grid-template-columns:1fr 1fr;gap:40px;align-items:start}
.acc-detail h4{font-size:1rem;color:#0c1f3f;font-weight:700;margin-bottom:14px;text-transform:uppercase;letter-spacing:.06em;font-size:.8rem}
.acc-detail ul{list-style:none}
.acc-detail ul li{display:flex;gap:.625rem;align-items:flex-start;font-size:clamp(.88rem,2vw,1rem);color:#5a5a5a;padding:.5rem 0;border-bottom:1px solid #f0efeb;line-height:1.55}
.acc-detail ul li:last-child{border-bottom:none}
.acc-detail ul li svg{flex-shrink:0;margin-top:3px;width:16px;height:16px;stroke:#c5a44e;fill:none;stroke-width:2.5}
.acc-pricing-box{background:linear-gradient(135deg,#0c1f3f,#162d55);border-radius:10px;padding:clamp(1.25rem,3vw,2rem);overflow:visible;width:100%}
.acc-pricing-box .from-lbl{font-size:.78rem;font-weight:700;letter-spacing:.14em;text-transform:uppercase;color:#c5a44e;margin-bottom:8px}
.acc-pricing-box .from-amt{font-family:'Playfair Display',serif;font-size:clamp(2rem,5vw,2.8rem);font-weight:700;color:#fff;margin-bottom:.375rem}
.acc-pricing-box .from-note{font-size:clamp(.85rem,2vw,.9rem);color:#a0aec0;margin-bottom:0;line-height:1.6}
.acc-pricing-box .acc-cta{display:none}
.acc-note-box{background:#f0efeb;border-left:3px solid #c5a44e;border-radius:0 8px 8px 0;padding:18px 20px;margin-top:20px;font-size:.92rem;color:#5a5a5a;line-height:1.7}
.acc-note-box strong{color:#0c1f3f}

/* WHAT'S INCLUDED STRIP */
.included-strip{padding:80px 0;background:#0c1f3f}
.included-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:28px;margin-top:48px}
.inc-card{text-align:center;padding:28px 20px}
.inc-card .inc-icon{width:56px;height:56px;border-radius:50%;background:rgba(197,164,78,.15);display:flex;align-items:center;justify-content:center;margin:0 auto 18px}
.inc-card .inc-icon svg{stroke:#c5a44e;fill:none;width:26px;height:26px;stroke-width:1.8}
.inc-card h4{font-family:'Playfair Display',serif;font-size:1.05rem;color:#fff;margin-bottom:8px}
.inc-card p{font-size:.9rem;color:#a0aec0;line-height:1.7}

/* SELF PAY GUIDE */
.selfpay{padding:90px 0;background:#fff}
.selfpay-grid{display:grid;grid-template-columns:1fr 1fr;gap:64px;align-items:start;margin-top:48px}
.selfpay-col h3{font-family:'Playfair Display',serif;font-size:1.5rem;color:#0c1f3f;margin-bottom:20px}
.selfpay-col p{font-size:clamp(.92rem,2vw,1rem);color:#5a5a5a;line-height:1.8;margin-bottom:1rem}
.step-list{list-style:none;counter-reset:step-counter}
.step-list li{counter-increment:step-counter;display:flex;gap:1rem;align-items:flex-start;margin-bottom:1.25rem;font-size:clamp(.9rem,2vw,1rem);color:#5a5a5a;line-height:1.7}
.step-list li::before{content:counter(step-counter);display:flex;align-items:center;justify-content:center;width:32px;height:32px;border-radius:50%;background:#0c1f3f;color:#fff;font-family:'Playfair Display',serif;font-weight:700;font-size:.9rem;flex-shrink:0;margin-top:2px}
.step-list li strong{color:#0c1f3f}
.insurance-grid{display:grid;grid-template-columns:1fr 1fr;gap:12px;margin-top:20px}
.ins-tick{display:flex;align-items:center;gap:10px;font-size:.95rem;color:#5a5a5a}
.ins-tick svg{stroke:#c5a44e;fill:none;width:16px;height:16px;stroke-width:2.5;flex-shrink:0}

/* INSURERS */
.insurers{padding:48px 0;background:#fff;border-top:1px solid #e2e0db}
.insurers h3{text-align:center;font-size:.78rem;font-weight:700;letter-spacing:.14em;text-transform:uppercase;color:#5a5a5a;margin-bottom:28px}
.ins-row{display:flex;align-items:center;justify-content:center;gap:28px;flex-wrap:wrap}
.ins-row img{height:50px;width:auto;object-fit:contain;opacity:.85;transition:all .3s}
.ins-row img:hover{opacity:1;transform:scale(1.05)}
.ins-badge{display:flex;align-items:center;height:50px;padding:8px 18px;background:#f0efeb;border-radius:6px;font-size:.82rem;font-weight:700;color:#5a5a5a}

/* FAQ */
.faq{padding:90px 0;background:#f0efeb}
.faq-layout{display:grid;grid-template-columns:1fr 1.6fr;gap:60px;align-items:start}
.faq-intro p{color:#5a5a5a;font-size:1rem;line-height:1.8;margin-bottom:28px}
.faq-list{display:flex;flex-direction:column;gap:12px}
.faq-item{background:#fff;border:1px solid #e2e0db;border-radius:8px;overflow:hidden}
.faq-item.active{border-color:#c5a44e}
.faq-q{display:flex;align-items:center;justify-content:space-between;padding:clamp(.875rem,2vw,1.375rem) clamp(1rem,3vw,1.75rem);cursor:pointer;gap:1rem;font-size:clamp(.92rem,2vw,1.02rem);font-weight:600;color:#0c1f3f;line-height:1.5}
.faq-q:hover{color:#c5a44e}
.faq-a{max-height:0;overflow:hidden;transition:max-height .4s ease}
.faq-item.active .faq-a{max-height:500px}
.faq-a-inner{padding:0 clamp(1rem,3vw,1.75rem) clamp(.875rem,2vw,1.375rem);font-size:clamp(.88rem,2vw,.98rem);color:#5a5a5a;line-height:1.8}

/* CTA */
.cta{padding:90px 0;background:linear-gradient(135deg,#0c1f3f,#162d55,#1a3460);text-align:center}
.cta h2{font-size:clamp(1.8rem,4vw,2.6rem);color:#fff;margin-bottom:16px}
.cta p{color:#a0aec0;max-width:560px;margin:0 auto 36px;font-size:1.05rem;line-height:1.8}
.cta-btns{display:flex;gap:16px;justify-content:center;flex-wrap:wrap}

/* FOOTER */
.footer{padding:48px 0 28px;background:#0c1f3f;border-top:1px solid rgba(255,255,255,.06)}
.footer-inner{display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:16px}
.footer-brand{font-family:'Playfair Display',serif;font-size:1rem;color:#fff;font-weight:600}
.footer-brand span{display:block;font-family:'DM Sans',sans-serif;font-size:.72rem;color:#a0aec0;font-weight:400;margin-top:2px}
.footer-links{display:flex;gap:24px}
.footer-links a{font-size:.8rem;color:#a0aec0}.footer-links a:hover{color:#c5a44e}
.footer-copy{font-size:.72rem;color:#a0aec0;text-align:center;margin-top:28px;padding-top:20px;border-top:1px solid rgba(255,255,255,.06)}

/* RESPONSIVE */

/* Tablet landscape */
@media(max-width:1024px){
  .price-grid{grid-template-columns:1fr 1fr;max-width:700px;margin-left:auto;margin-right:auto}
  .acc-grid{grid-template-columns:1fr}
  .acc-pricing-box{margin-top:24px}
  .selfpay-grid{grid-template-columns:1fr}
  .faq-layout{grid-template-columns:1fr}
  .faq-intro{margin-bottom:36px}
  .consult-fees{padding:70px 0}
  .proc-fees{padding:70px 0}
  .selfpay{padding:70px 0}
  .faq{padding:70px 0}
}

/* Tablet portrait */
@media(max-width:768px){
  body{font-size:16px}
  .nav-links{display:none;position:fixed;top:130px;left:0;right:0;background:#fff;flex-direction:column;padding:20px 24px;gap:0;border-bottom:2px solid #e2e0db;box-shadow:0 8px 24px rgba(0,0,0,.1);z-index:999}
  .nav-links.show{display:flex}
  .nav-links li{padding:12px 0;border-bottom:1px solid #f0efeb}
  .nav-links li:last-child{border-bottom:none}
  .nav-mobile{display:block;background:none;border:none;cursor:pointer;padding:8px}
  .nav-dropdown .dropdown-menu{position:static;box-shadow:none;border:none;padding:4px 0 0 16px;min-width:auto;display:none}
  .nav-dropdown.open .dropdown-menu{display:block}
  /* Hero */
  .page-hero{padding:150px 0 60px}
  .page-hero h1{font-size:2rem}
  .page-hero p{font-size:1rem}
  .page-hero-badges{gap:10px}
  .hero-badge{font-size:.82rem;padding:7px 14px}
  /* Consultations */
  .price-grid{grid-template-columns:1fr;max-width:460px;margin-left:auto;margin-right:auto}
  .price-card{padding:32px 28px}
  .price-amt{font-size:2.4rem}
  /* Accordion */
  .acc-header{padding:20px 20px;gap:12px}
  .acc-inner{padding:0 20px 28px}
  .acc-title{font-size:1.05rem}
  .acc-subtitle{font-size:.82rem}
  .acc-price-preview{display:none}
  .acc-icon{width:44px;height:44px}
  .acc-icon svg{width:20px;height:20px}
  .acc-pricing-box{padding:24px 20px}
  .acc-pricing-box .from-amt{font-size:2.2rem}
  /* Self-pay */
  .selfpay-col h3{font-size:1.3rem}
  .insurance-grid{grid-template-columns:1fr}
  /* FAQ */
  .faq-q{font-size:.95rem;padding:18px 20px}
  .faq-a-inner{padding:0 20px 18px;font-size:.92rem}
  /* Section spacing */
  .consult-fees{padding:60px 0}
  .proc-fees{padding:60px 0}
  .selfpay{padding:60px 0}
  .faq{padding:60px 0}
  .cta{padding:60px 0}
  /* Footer */
  .footer-inner{flex-direction:column;align-items:flex-start;gap:20px}
  .footer-links{flex-wrap:wrap;gap:16px}
}

/* Mobile */
@media(max-width:480px){
  body{font-size:15px}
  .page-hero{padding:140px 0 50px}
  .page-hero h1{font-size:1.75rem}
  .page-hero-badges{flex-direction:column;gap:8px}
  .hero-badge{width:100%}
  /* Consultations */
  .price-grid{max-width:100%}
  .price-card{padding:28px 20px}
  .price-amt{font-size:2.2rem}
  .price-feat li{font-size:.88rem}
  /* Accordion */
  .acc-header{padding:16px 16px;gap:10px}
  .acc-inner{padding:0 16px 24px}
  .acc-icon{width:40px;height:40px}
  .acc-icon svg{width:18px;height:18px}
  .acc-title{font-size:1rem}
  .acc-subtitle{font-size:.78rem}
  .acc-note-box{font-size:.85rem;padding:14px 16px}
  .acc-detail ul li{font-size:.9rem}
  .acc-pricing-box{padding:20px 16px}
  .acc-pricing-box .from-amt{font-size:2rem}
  .acc-pricing-box .from-note{font-size:.82rem}
  .acc-cta{font-size:.88rem;padding:12px 16px}
  /* Self-pay */
  .step-list li{font-size:.9rem;gap:12px}
  .step-list li::before{width:28px;height:28px;font-size:.8rem;flex-shrink:0}
  .selfpay-col p{font-size:.92rem}
  /* Insurers */
  .ins-row{gap:16px}
  .ins-row img{height:40px}
  /* FAQ */
  .faq-q{font-size:.9rem;padding:16px 16px}
  .faq-a-inner{padding:0 16px 16px;font-size:.88rem}
  /* CTA */
  .cta h2{font-size:1.7rem}
  .cta p{font-size:.95rem}
  .cta-btns{flex-direction:column;align-items:center}
  .cta-btns .btn{width:100%;justify-content:center}
  /* Footer */
  .footer-links{gap:12px}
}
</style>
</head>
