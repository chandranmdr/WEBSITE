.page-hero .slabel{color:#c5a44e}
.page-hero h1{font-size:clamp(2rem,5vw,3rem);color:#fff;margin-bottom:12px}
.page-hero .hero-sub{font-size:1.1rem;color:#a0aec0;line-height:1.8;max-width:700px;margin-bottom:32px}
