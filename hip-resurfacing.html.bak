.footer-copy{font-size:.72rem;color:#a0aec0;text-align:center;margin-top:24px;padding-top:16px;border-top:1px solid rgba(255,255,255,.06)}

/* RESPONSIVE */
@media(max-width:1024px){.two-col{grid-template-columns:1fr}.implant-grid{grid-template-columns:1fr}.three-col{grid-template-columns:1fr}.adv-grid{grid-template-columns:1fr}}
@media(max-width:768px){
.nav-links{display:none;position:fixed;top:130px;left:0;right:0;background:#fff;flex-direction:column;padding:20px 24px;gap:0;border-bottom:2px solid #e2e0db;box-shadow:0 8px 24px rgba(0,0,0,.1);z-index:999}
.nav-links.show{display:flex}
