.img-placeholder{width:100%;aspect-ratio:16/10;border-radius:10px;background:#f0efeb;border:1px solid #e2e0db;display:flex;align-items:center;justify-content:center;color:#999;font-size:.85rem;text-align:center;padding:24px}

/* FAQ */
.faq-list{display:flex;flex-direction:column;gap:12px;margin-top:32px}
