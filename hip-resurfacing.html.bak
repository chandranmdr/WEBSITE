.three-col{display:grid;grid-template-columns:repeat(3,1fr);gap:28px}

/* CARDS */
.info-card{background:#fff;border:1px solid #e2e0db;border-radius:10px;padding:32px 24px;transition:all .35s}
.info-card:hover{transform:translateY(-4px);box-shadow:0 2px 20px rgba(12,31,63,.06)}
.info-card h3{font-size:1.05rem;color:#0c1f3f;margin-bottom:10px}
.info-card p{font-size:.85rem;color:#5a5a5a;line-height:1.65}
.info-card .card-tag{display:inline-block;background:rgba(197,164,78,.12);color:#c5a44e;font-size:.7rem;font-weight:700;letter-spacing:.06em;text-transform:uppercase;padding:4px 12px;border-radius:20px;margin-bottom:14px}

/* IMPLANT TABLE */
.implant-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:24px;margin-top:32px}
.implant-card{background:#fff;border:1px solid #e2e0db;border-radius:10px;padding:28px 24px;text-align:center;position:relative;overflow:hidden}
.implant-card::before{content:'';position:absolute;top:0;left:0;right:0;height:3px;background:#c5a44e}
.implant-card h3{font-size:1rem;color:#0c1f3f;margin-bottom:6px}
.implant-card .maker{font-size:.78rem;color:#c5a44e;font-weight:600;margin-bottom:12px}
.implant-card p{font-size:.85rem;color:#5a5a5a;line-height:1.65}
.implant-card .bearing{display:inline-block;background:#f0efeb;padding:4px 12px;border-radius:20px;font-size:.72rem;font-weight:700;color:#0c1f3f;margin-bottom:12px}

/* ADVANTAGES */
.adv-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:20px;margin-top:32px}
.adv-item{display:flex;align-items:flex-start;gap:12px;font-size:.9rem;color:#333;line-height:1.65}
.adv-item svg{flex-shrink:0;margin-top:3px;width:20px;height:20px;stroke:#c5a44e;fill:none;stroke-width:2.5}

/* TIMELINE */
.timeline{display:flex;gap:0;margin-top:32px;position:relative}
.timeline::before{content:'';position:absolute;top:24px;left:0;right:0;height:2px;background:#e2e0db}
.timeline-step{flex:1;text-align:center;position:relative}
.timeline-dot{width:12px;height:12px;border-radius:50%;background:#c5a44e;margin:18px auto 16px;position:relative;z-index:1}
.timeline-label{font-size:.72rem;font-weight:700;color:#c5a44e;text-transform:uppercase;letter-spacing:.08em}
.timeline-desc{font-size:.82rem;color:#5a5a5a;margin-top:6px;padding:0 8px}

/* TESTIMONIAL */
.test-feature{background:rgba(255,255,255,.04);border:1px solid rgba(255,255,255,.08);border-radius:10px;padding:40px;max-width:800px;margin:32px auto 0}
.test-feature .test-stars{color:#c5a44e;font-size:1.2rem;margin-bottom:16px}
.test-feature .test-text{font-size:1rem;color:#a0aec0;line-height:1.8;font-style:italic;margin-bottom:20px}
