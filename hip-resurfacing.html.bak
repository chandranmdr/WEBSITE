/* PATIENT STORY */
.story-card{background:#fff;border:1px solid #e2e0db;border-radius:10px;padding:32px;text-align:center;max-width:600px;margin:32px auto 0}
.story-card p{font-size:.9rem;color:#5a5a5a;margin-bottom:20px}

/* CTA */
.cta{padding:80px 0;background:linear-gradient(135deg,#0c1f3f,#162d55,#1a3460);text-align:center}
.cta h2{font-size:clamp(1.6rem,3.5vw,2.2rem);color:#fff;margin-bottom:16px}
.cta p{color:#a0aec0;max-width:560px;margin:0 auto 32px;font-size:1rem;line-height:1.75}
.cta-btns{display:flex;gap:16px;justify-content:center;flex-wrap:wrap}

/* FOOTER */
.footer{padding:40px 0 24px;background:#0c1f3f;border-top:1px solid rgba(255,255,255,.06)}
.footer-inner{display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:16px}
